#!/bin/bash

# .chezmoidata/packages.yaml hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }}

# This script initializes Atlassian CLI authentication.
# It runs whenever the packages configuration changes, ensuring acli is likely installed.

if command -v acli &> /dev/null && command -v op &> /dev/null; then
    echo "Checking Atlassian CLI authentication status..."

    # Axelerant Jira
    if ! acli jira auth switch --site axelerant.atlassian.net &> /dev/null; then
        echo "Authenticating with Axelerant Jira..."
        op read "op://Employee/n3enjt4hnmrdq7czug6nlkzpti/credential" --account axelerant.1password.com | acli jira auth login --site axelerant.atlassian.net --email hussain@axelerant.com --token || echo "Axelerant Jira login failed (maybe 1Password is locked?)"
    else
        echo "Axelerant Jira already authenticated."
    fi

    # Momentus Jira
    if ! acli jira auth switch --site ungerboeck.atlassian.net &> /dev/null; then
        echo "Authenticating with Momentus Jira..."
        op read "op://Employee/Momentus Jira/credential" --account axelerant.1password.com | acli jira auth login --site ungerboeck.atlassian.net --email hussain_abbas@gomomentus.com --token || echo "Momentus Jira login failed (maybe 1Password is locked?)"
    else
        echo "Momentus Jira already authenticated."
    fi
else
    echo "Skipping Atlassian CLI auth: acli or op not found."
fi
