{{ if .personal -}}
# Atuin history
eval "$(atuin init zsh --disable-up-arrow)"
{{- end }}

# Basic Zsh settings
autoload -Uz compinit
compinit

# Aliases
{{ range $key, $val := .aliases -}}
alias {{ $key }}='{{ $val }}'
{{ end }}

HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE

# Functions
function lcommit() {
    local diff=$(git diff --cached)
    if [[ -z "$diff" ]]; then
        echo "No staged changes found."
        return 1
    fi

    local context="$*"
    local system_prompt='Write a concise, conventional commit-style message describing these changes. Use the proper type: feat, fix, chore, ci, docs, refactor, style, or test.

For example:
- use chore for dependency updates.
- use ci for changes to GitHub Actions or other pipelines.
- and so on.
'

    if [[ -n "$context" ]]; then
        system_prompt="$system_prompt
Additional context: $context"
    fi

    local msg=$(echo "$diff" | llm --system "$system_prompt")
    printf "%s" "$msg" | tee /dev/tty | pbcopy
    printf "\n"
}
