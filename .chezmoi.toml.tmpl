{{/* boolean feature tags */}}
{{- $macos := false -}}
{{- $rpi := false -}}
{{- $computerName := .chezmoi.hostname -}}

{{- if eq .chezmoi.os "darwin" -}}
{{-   $macos = true -}}
{{-   $computerName = output "scutil" "--get" "ComputerName" | trim -}}
{{- end -}}

{{- $is_workstation := false -}}
{{- if eq $computerName "the-good-machine" -}}
{{-   $is_workstation = true -}}
{{- end -}}

{{- $is_personal := false -}}
{{- if eq $computerName "the-good-machine" "tiny-tardis" "eressea" -}}
{{-   $is_personal = true -}}
{{- end -}}

{{- if eq .chezmoi.hostname "grey-havens" -}}
{{-   $rpi = true -}}
{{- end -}}

{{- $personal := promptBool "Is this machine personal use and has additional tools" (default $is_personal .personal) -}}

{{- $default_stack := "base" -}}
{{- if $is_workstation -}}
{{-   $default_stack = "full" -}}
{{- end -}}
{{- $stack := promptString "Software stack (base, container, full)" (default $default_stack .stack) -}}

{{- $email := promptString "Your email address" (default "hussainweb@gmail.com" .email) -}}
{{- $proxmox_endpoint := "" -}}
{{- if $personal -}}
{{-   $proxmox_endpoint = promptString "Proxmox API endpoint URL" (default "https://erebor.husain.me:8006/api2/json" .proxmox_endpoint) -}}
{{- end -}}

{{- $ssh_host := not $macos -}}
{{- "" -}}

[data]
  personal = {{ $personal }}
  stack = {{ $stack | quote }}
  workstation = {{ $is_workstation }}
  macos = {{ $macos }}
  rpi = {{ $rpi }}
  ssh_host = {{ $ssh_host }}
  email = {{ $email | quote }}
  computerName = {{ $computerName | quote }}
  proxmox_endpoint = {{ $proxmox_endpoint | quote }}

[hooks.read-source-state.pre]
    command = ".local/share/chezmoi/.install-1password.sh"
